# ─── FlatClaw — environment configuration ─────────────────────────────────
#
# Copy to `.env` (gitignored). Local development only — production deploys
# get their environment from Northflank's secret manager and GCP, not this file.
#
# Per-component env reference:
#   - flatclaw-memory:  TENANT_ID, FLATCLAW_MEMORY_*, FLATCLAW_EMBEDDING_*
#   - console (Next.js): NEXT_PUBLIC_GATEWAY_URL  (also see console/.env.example)
#   - inference image:  MODEL_DIR, GEMMA_DIR_NAME, PORT, MAX_CONTEXT, TP
#                       (Northflank manifest sets these in production; values
#                       here matter only when running the image locally)
#   - tenant provisioning: NORTHFLANK_API_TOKEN, GOOGLE_APPLICATION_CREDENTIALS,
#                          KAGGLE_USERNAME, KAGGLE_KEY  (operator-only, .env.local)

# ─── Tenant ────────────────────────────────────────────────────────────────
# Identifies the tenant for memory + RAG namespacing. Generated per-tenant
# in production by provision-tenant.sh.
TENANT_ID=00000000-0000-0000-0000-000000000000

# ─── FlatClaw Memory (method-of-loci) ──────────────────────────────────────
# Local dev: repo-relative paths under .data/ (gitignored).
# Production: persistent volumes mounted into the Memory Northflank service.
FLATCLAW_MEMORY_SQLITE=./.data/memory.db
FLATCLAW_MEMORY_CHROMA=./.data/chroma
FLATCLAW_MEMORY_URL=http://localhost:8790

# Embeddings. Default (unset): Chroma's bundled ONNX all-MiniLM-L6-v2 (384-dim,
# CPU-only, ~80 MB first-use download). Production: point at the inference
# service for bge-m3 (1024-dim, runs co-resident with Gemma on the Blackwell
# GPU). The URL is the public Northflank URL of the inference service.
# FLATCLAW_EMBEDDING_URL=https://flatclaw-inference--<tenant>.code.run
# FLATCLAW_EMBEDDING_MODEL=bge-m3

# ─── FlatClaw Console (Next.js) ────────────────────────────────────────────
# Upstream OpenClaw Gateway WebSocket. Local: a locally-running OpenClaw on
# port 18789. Production: the OpenClaw Gateway Northflank service URL.
NEXT_PUBLIC_GATEWAY_URL=ws://127.0.0.1:18789

# ─── Inference image (entrypoint.sh defaults) ──────────────────────────────
# These have sensible defaults baked into the image. Override only when
# running the inference image manually for local testing.
# MODEL_DIR=/workspace/models
# GEMMA_DIR_NAME=gemma-4-31B-it
# PORT=8000
# MAX_CONTEXT=32768
# TP=1
# SGLANG_EXTRA_ARGS=--api-key your-bearer-token-for-tls-protected-endpoint

# ─── Operator credentials (NEVER COMMIT — use .env.local only) ────────────
# Used only by infra/scripts/provision-tenant.sh to bring up new tenants.
# Not read by any deployed service.
#
# NORTHFLANK_API_TOKEN=nf-...
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/.gcp/service-account.json
# KAGGLE_USERNAME=your-kaggle-username
# KAGGLE_KEY=your-kaggle-api-key
