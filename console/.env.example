# FlatClaw Console — local dev environment overrides.
# Copy to .env.local (gitignored).

# Upstream OpenClaw Gateway WebSocket URL. Default: ws://127.0.0.1:18789.
# Production: set to the Northflank-managed Gateway service URL for the tenant.
NEXT_PUBLIC_GATEWAY_URL=ws://127.0.0.1:18789

# Optional override for Console's local state directory.
# Default: ~/.openclaw/flatclaw-console/
# OPENCLAW_STATE_DIR=/path/to/state

# Optional: override the SSH target used for gateway-host operations.
# Used when deleting agents — moves their workspace/state into the gateway
# host's trash directory. Leave empty to derive from NEXT_PUBLIC_GATEWAY_URL.
# OPENCLAW_GATEWAY_SSH_TARGET=

# Optional: SSH user when SSH target is derived from the gateway URL.
# Default: ubuntu
# OPENCLAW_GATEWAY_SSH_USER=
